{
  "expo": {
    "name": "Peony Care Food App",
    "slug": "peony-care-food-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peonycare.foodapp"
    },
    "android": {
      "package": "com.peonycare.foodapp",
      "adaptiveIcon": {
        "backgroundColor": "#D31B1B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Peony Care needs camera access to scan claim QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7303ed9e-0243-4ce6-b3d8-4c75bd5509f7"
      }
    }
  }
}
