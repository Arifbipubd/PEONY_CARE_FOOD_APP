{
  "cli": {
    "version": ">= 18.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "withoutCredentials": false,
        "env": {
          "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "env": {
          "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a"
        }
      }
    }
  }
}
